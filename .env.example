# Environment Variables

Copy this file to `.env` and fill in your values.

# Required: GitHub Personal Access Token
# Generate at: https://github.com/settings/tokens/new
# Required scopes: read:user, repo (for private repo stats)
PAT_1=your_github_personal_access_token_here

# Optional: Additional PAT tokens for load balancing (up to PAT_10)
# Uncomment and set as many as needed:
# PAT_2=your_second_token_here
# PAT_3=your_third_token_here

# Optional: WakaTime API key (only needed for WakaTime card)
# Generate at: https://wakatime.com/settings/api-key
# WAKATIME_API_KEY=your_wakatime_api_key_here

# Optional: Node environment
# NODE_ENV=development
